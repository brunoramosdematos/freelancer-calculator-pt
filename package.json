{
  "name": "remotefreelancept",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "verify:production-build": "node scripts/verify-production-build.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "audit:critical": "npm audit --audit-level=critical",
    "preview": "vite preview",
    "vitest": "vitest",
    "coverage": "vitest run --coverage",
    "cy:e2e:open": "node scripts/run-cypress-e2e.mjs open",
    "cy:e2e:run": "node scripts/run-cypress-e2e.mjs run",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
    "format": "prettier .  --write"
  },
  "dependencies": {
    "@heroicons/vue": "^2.1.1",
    "@vueuse/core": "^10.7.2",
    "chart.js": "^4.4.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "click-outside-vue3": "^4.0.1",
    "pinia": "^2.0.22",
    "vue": "^3.2.37",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.3",
    "autoprefixer": "^10.4.17",
    "cypress": "^15.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.20.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.2.4",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
